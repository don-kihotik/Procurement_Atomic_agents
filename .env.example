# Какой провайдер LLM использовать: local | stub | claude | yandex
LLM_PROVIDER=stub

# --- Фаза 1: локально на Ollama ---
OLLAMA_MODEL=gemma4
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Фаза 2: Claude ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Фаза 3: Яндекс AI Studio (OpenAI-совместимый эндпоинт) ---
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt/latest
YANDEX_BASE_URL=https://llm.api.cloud.yandex.net/v1
